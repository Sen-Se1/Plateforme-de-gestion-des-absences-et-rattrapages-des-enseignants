# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gestion_absences

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Uploads
UPLOAD_DIR=./uploads/justificatifs
MAX_UPLOAD_SIZE=5242880  # 5MB
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
# SMTP_SECURE="true"
SMTP_FROM="Gestion des Absences <your-email@gmail.com>"
# SMTP_SUPPORT_MAIL="your-email@gmail.com"

# AI
AI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxx